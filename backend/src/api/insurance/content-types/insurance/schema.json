{
  "kind": "collectionType",
  "collectionName": "insurances",
  "info": {
    "singularName": "insurance",
    "pluralName": "insurances",
    "displayName": "Insurance",
    "description": "Horse insurance information"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "horse": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::horse.horse",
      "mappedBy": "insurance"
    },
    "provider": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "policyNo": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "startDate": {
      "type": "date",
      "required": true
    },
    "endDate": {
      "type": "date",
      "required": true
    },
    "coverageAmount": {
      "type": "decimal"
    },
    "premium": {
      "type": "decimal"
    },
    "coverage": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": ["active", "expired", "cancelled"],
      "default": "active"
    },
    "renewalReminder": {
      "type": "boolean",
      "default": true
    }
  }
}
